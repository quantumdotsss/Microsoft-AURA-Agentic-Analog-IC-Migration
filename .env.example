# Dry-run exercises the full graph without invoking licensed EDA binaries.
AURA_DRY_RUN=true

# Cadence binaries and optional shell setup. These are used only when
# AURA_DRY_RUN=false.
SPECTRE_BIN=spectre
OCEAN_BIN=ocean
AURA_CADENCE_SETUP=

# Model paths must point to files you are licensed to use.
AURA_PTM22_MODEL_PATH=
AURA_GPDK045_MODEL_PATH=
AURA_ASAP7_MODEL_PATH=

# Execution limits.
AURA_COMPILE_TIMEOUT_SEC=120
AURA_OCEAN_TIMEOUT_SEC=300
AURA_MAX_ITERATIONS=3
AURA_MAX_RETARGET_ATTEMPTS=3
AURA_MAX_COMPILE_DEBUG_ATTEMPTS=3
