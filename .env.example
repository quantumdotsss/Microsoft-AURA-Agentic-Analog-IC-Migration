# Default is dry-run because this laptop is not connected to the UCI Cadence host.
# Set to false on zuma/eecs after sourcing Cadence.
AURA_DRY_RUN=true

# Cadence binaries. These are used only when AURA_DRY_RUN=false.
SPECTRE_BIN=spectre
OCEAN_BIN=ocean

# Optional tcsh/csh setup command to run before Cadence tools.
# Example on UCI EECS:
# AURA_CADENCE_SETUP="source /ecelib/linware/profile/cadence616"
AURA_CADENCE_SETUP=

# Loop limits.
AURA_MAX_ITERATIONS=3
AURA_MAX_RETARGET_ATTEMPTS=3
AURA_MAX_COMPILE_DEBUG_ATTEMPTS=3

